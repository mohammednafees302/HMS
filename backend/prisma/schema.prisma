// ============================================================
// prisma/schema.prisma
// HMS Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PATIENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PatientStatus {
  ACTIVE
  DISCHARGED
  CRITICAL
  DECEASED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  CONSULTATION
  FOLLOW_UP
  CHECKUP
  EMERGENCY
  NEW_PATIENT
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

// ============================================================
// MODELS
// ============================================================

// ---- User (Staff accounts) ----
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String
  name           String
  role           UserRole @default(PATIENT)
  phone          String?
  avatarUrl      String?
  resetToken     String?
  resetTokenExp  DateTime?
  isActive       Boolean  @default(true)
  tokenVersion   Int      @default(0) // bump to invalidate all refresh tokens
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  doctorProfile  Doctor?
  patientProfile Patient?
  notifications  Notification[]

  @@map("users")
}

// ---- Department ----
model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  headId      String?  // FK to Doctor
  totalBeds   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  doctors      Doctor[]
  appointments Appointment[]

  @@map("departments")
}

// ---- Doctor ----
model Doctor {
  id               String   @id @default(uuid())
  userId           String   @unique
  departmentId     String
  specialization   String
  qualification    String
  experience       Int      @default(0) // years
  availability     String?  // e.g. "Mon-Fri 9am-5pm"
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id])
  appointments Appointment[]

  @@map("doctors")
}

// ---- Patient ----
model Patient {
  id           String        @id @default(uuid())
  patientCode  String        @unique @default(uuid()) // Automatically unique
  name         String
  age          Int
  gender       String        @default("Male")
  bloodType    String?
  phone        String
  department   String?       // Matches UI 'dept'
  doctor       String?       // Matches UI 'doctor'
  diagnosis    String?
  roomNumber   String?
  userId       String?       @unique // Link to User for patient logins
  status       PatientStatus @default(ACTIVE)
  admittedAt   DateTime      @default(now())
  dischargedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  invoices     Invoice[]
  medicalRecords MedicalRecord[]
  prescriptions  Prescription[]
  labTests       LabTest[]
  documents      PatientDocument[]

  @@map("patients")
}

// ---- Appointment ----
model Appointment {
  id           String            @id @default(uuid())
  patientId    String
  doctorId     String
  departmentId String?
  type         AppointmentType   @default(CONSULTATION)
  status       AppointmentStatus @default(SCHEDULED)
  scheduledAt  DateTime
  duration     Int               @default(30) // minutes
  roomNumber   String?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Relations
  patient      Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       Doctor      @relation(fields: [doctorId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])

  @@map("appointments")
}

// ---- Invoice ----
model Invoice {
  id          String        @id @default(uuid())
  invoiceCode String        @unique // e.g. INV-001
  patientId   String
  amount      Decimal       @db.Decimal(10, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(10, 2)
  status      InvoiceStatus @default(PENDING)
  items       Json          // Array of { description, quantity, unitPrice, total }
  notes       String?
  issuedAt    DateTime      @default(now())
  dueAt       DateTime
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ---- Medical Record (EHR) ----
model MedicalRecord {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String?  // optional link to doctor user id (not Doctor model)
  doctorName      String?
  visitDate       DateTime @default(now())
  chiefComplaint  String?
  symptoms        String?
  diagnosis       String
  treatmentPlan   String?
  medications     Json?    // snapshot of prescribed meds
  notes           String?
  followUpDate    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("medical_records")
}

// ---- Prescription ----
enum PrescriptionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  ON_HOLD
}

model Prescription {
  id          String             @id @default(uuid())
  patientId   String
  doctorId    String?
  doctorName  String?
  medications Json               // Array of { name, dosage, frequency, duration, instructions, quantity }
  diagnosis   String?
  notes       String?
  status      PrescriptionStatus @default(ACTIVE)
  issuedAt    DateTime           @default(now())
  validUntil  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  patient     Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("prescriptions")
}

// ---- Lab Test ----
enum LabTestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LabTestCategory {
  BLOOD
  URINE
  STOOL
  IMAGING
  BIOPSY
  MICROBIOLOGY
  GENETIC
  OTHER
}

model LabTest {
  id           String          @id @default(uuid())
  patientId    String
  orderedById  String?
  orderedByName String?
  testName     String
  category     LabTestCategory @default(OTHER)
  status       LabTestStatus   @default(PENDING)
  priority     String          @default("NORMAL") // NORMAL, URGENT, STAT
  result       String?
  resultNotes  String?
  fileUrl      String?         // uploaded result file
  fileName     String?
  orderedAt    DateTime        @default(now())
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("lab_tests")
}

// ---- Patient Document ----
enum DocumentCategory {
  CONSENT_FORM
  INSURANCE
  DISCHARGE_SUMMARY
  REFERRAL_LETTER
  IMAGING
  LAB_REPORT
  PRESCRIPTION
  OTHER
}

model PatientDocument {
  id           String           @id @default(uuid())
  patientId    String
  uploadedById String?
  title        String
  category     DocumentCategory @default(OTHER)
  fileUrl      String
  fileName     String
  mimeType     String?
  fileSize     Int?             // bytes
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  patient      Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_documents")
}

// ---- Notification ----
model Notification {
  id         String   @id @default(uuid())
  title      String
  message    String
  type       String   @default("INFO")
  entityType String
  entityId   String?
  userId     String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
